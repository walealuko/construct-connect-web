# Construct Hub — environment template
# Copy to .env.local and fill in real values. .env.local is git-ignored.
#
# RLS migrations: applied manually in the Supabase SQL editor in
# numeric order from supabase/migrations/. There is no
# `supabase db push` automation.

# --- Supabase (browser-safe, public) ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# --- Supabase (server only — DO NOT prefix NEXT_PUBLIC_) ---
# Used by server actions that need to bypass RLS (admin ops, the
# admin.updateUserById metadata sync on signup, etc.).
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# --- Paystack (server only) ---
# Used to initialize and verify transactions in app/api/payments/*.
PAYSTACK_SECRET_KEY=sk_test_xxx_or_live_key

# --- App base URL (browser-safe) ---
# Pin instead of trusting the `Origin` header so the Paystack
# callback URL is stable across localhost, preview deploys, and
# production.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
